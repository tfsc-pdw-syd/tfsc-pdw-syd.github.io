# Gmail address used to send emails
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-16-char-app-password

# Where submissions are forwarded (organiser inbox)
RECIPIENT_EMAIL=mengjia.wu@uts.edu.au

# Admin dashboard password token (make it long and random, e.g. openssl rand -hex 32)
ADMIN_TOKEN=replace-with-a-long-random-string

# Where submitted files are stored (set to your Render Disk mount path)
SUBMISSIONS_DIR=/data/submissions
